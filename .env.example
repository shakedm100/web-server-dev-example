# MySQL connection string for SQLAlchemy
DATABASE_URL=mysql+pymysql://user:password@localhost:3306/ebooks

# Absolute or relative path to the folder containing PDF and EPUB files
# Relative paths resolve from the backend/ directory (where uvicorn runs)
BOOKS_DIR=../books

# Base URL of the FastAPI backend (used by the Vite frontend)
VITE_API_BASE_URL=http://localhost:8000
